# Elasticsearch connection
ES_URL=https://novaelastic-ecac65.es.eastus.azure.elastic.cloud

# Read-only, index-scoped API key (the base64 "id:key" blob from Kibana).
# NEVER commit the real value. Set this in Azure App Service > Configuration.
ES_API_KEY=WThTOUs1OEI5R3dVMmZ0ZHFRYmg6aGVMLUlSQlVOVE1oT05hZmhfaHdJdw==

# Default index alias when a tool call omits "index".
# Allowed aliases: java_application_logs, wm_api, wm_messages, openshift
DEFAULT_INDEX_ALIAS=java_application_logs

# Optional bearer token required by /mcp when set.
MCP_AUTH_TOKEN=REPLACE_WITH_LONG_RANDOM_TOKEN

# TLS: set to "false" ONLY for a self-signed test cluster.
# Prefer providing ES_CA_CERT instead of disabling verification.
ES_TLS_REJECT_UNAUTHORIZED=true
# ES_CA_CERT="-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----"


